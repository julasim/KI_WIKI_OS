# Telegram Bot Token (von @BotFather)
TG_TOKEN=your_telegram_bot_token_here

# Deine Telegram User-ID (von @userinfobot — schick "/start" zum @userinfobot)
ALLOWED_USER_ID=your_telegram_user_id_here

# OpenRouter API Key (von openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Modell-Auswahl (alle OpenRouter-Modelle möglich)
LLM_MODEL=anthropic/claude-sonnet-4-5
VISION_MODEL=anthropic/claude-sonnet-4-5

# Whisper-Konfiguration (lokal im Container)
# Modelle: tiny, base, small, medium, large-v3
# small = guter Trade-off für CPU + Deutsch (~244M params)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_LANG=de
