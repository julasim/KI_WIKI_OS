# ───────────── Telegram ─────────────
TG_TOKEN=your_telegram_bot_token_here
# 0 = Setup-Modus: Bot meldet die User-ID beim ersten Kontakt
ALLOWED_USER_ID=0

# ───────────── LLM-Provider ─────────────
# Beliebiger OpenAI-API-kompatibler Endpoint:
#
#   OpenRouter:    LLM_BASE_URL=https://openrouter.ai/api/v1
#                  LLM_MODEL=anthropic/claude-sonnet-4-5
#                  LLM_MODEL=google/gemini-2.5-flash
#                  LLM_MODEL=openai/gpt-4o-mini
#
#   Ollama Cloud:  LLM_BASE_URL=https://ollama.com/v1
#                  LLM_MODEL=gpt-oss:120b-cloud
#                  LLM_MODEL=qwen3:235b-cloud
#
#   OpenAI direkt: LLM_BASE_URL=https://api.openai.com/v1
#                  LLM_MODEL=gpt-4o-mini
#
LLM_API_KEY=your_provider_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-5

# ───────────── Vision (Photos) ─────────────
# Optional: separater Provider für Vision (falls Haupt-LLM kein Vision kann).
# Default: gleicher Provider wie LLM.
# Beispiel — Ollama Cloud für Text + Gemini Flash für Vision:
#   VISION_API_KEY=<openrouter-key>
#   VISION_BASE_URL=https://openrouter.ai/api/v1
#   VISION_MODEL=google/gemini-2.5-flash
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# ───────────── Whisper (Voice → Text) ─────────────
# Modelle: tiny, base, small, medium, large-v3
# small = guter Trade-off CPU + Deutsch (~244M params, ~500MB RAM)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_LANG=de

# ───────────── Backward-Kompat ─────────────
# Falls schon gesetzt: wird als Fallback für LLM_API_KEY verwendet.
# OPENROUTER_API_KEY=...
